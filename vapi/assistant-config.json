{
  "name": "Summit Health OB/GYN Scheduler",
  "firstMessage": "Thanks for calling Summit Health OB-GYN, this is Sage. Are you calling to book, reschedule, or ask about an existing appointment?",
  "model": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "systemPromptFile": "system-prompt.md",
    "temperature": 0.4,
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "check_availability",
          "description": "Check open appointment slots for a given visit type, provider, and date range.",
          "parameters": {
            "type": "object",
            "properties": {
              "visit_type": {
                "type": "string",
                "enum": ["new_ob_intake", "routine_prenatal", "high_risk_prenatal", "annual_wellness", "problem_visit", "procedure"]
              },
              "provider": { "type": "string", "description": "Preferred provider name, or 'any'" },
              "date_range_start": { "type": "string", "description": "ISO date, earliest acceptable" },
              "date_range_end": { "type": "string", "description": "ISO date, latest acceptable" }
            },
            "required": ["visit_type", "date_range_start", "date_range_end"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "check_patient_history",
          "description": "Look up a patient's prior no-show/late-cancellation pattern to inform confirmation strategy.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "dob": { "type": "string", "description": "ISO date of birth" }
            },
            "required": ["patient_name", "dob"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "book_appointment",
          "description": "Book a new appointment for a patient.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "dob": { "type": "string" },
              "phone": { "type": "string" },
              "visit_type": { "type": "string" },
              "provider": { "type": "string" },
              "slot_datetime": { "type": "string", "description": "ISO 8601 datetime" },
              "notes": { "type": "string" }
            },
            "required": ["patient_name", "dob", "phone", "visit_type", "provider", "slot_datetime"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "book_linked_appointment",
          "description": "Book a linked ultrasound + provider follow-up pair for double-resource visits. Ultrasound must be sequenced before the follow-up.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "dob": { "type": "string" },
              "phone": { "type": "string" },
              "ultrasound_slot": { "type": "string", "description": "ISO 8601 datetime, must be earlier than followup_slot" },
              "followup_slot": { "type": "string", "description": "ISO 8601 datetime" },
              "provider": { "type": "string" }
            },
            "required": ["patient_name", "dob", "phone", "ultrasound_slot", "followup_slot", "provider"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "transfer_to_nurse",
          "description": "Immediately transfer the call to a live nurse for any red-flag symptom (bleeding, decreased fetal movement, contractions, severe pain, suspected post-op complication, etc.). Ends the scheduling flow.",
          "parameters": {
            "type": "object",
            "properties": {
              "reason": { "type": "string", "description": "Brief description of the red-flag symptom reported" }
            },
            "required": ["reason"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "reschedule_appointment",
          "description": "Move an existing appointment to a new slot, freeing the old slot for waitlist backfill. Looks the appointment up by patient name and approximate current date/time — never ask the patient for an internal appointment ID, they won't know it.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "current_slot_datetime": { "type": "string", "description": "The date/time the patient believes their existing appointment is at, ISO 8601 (best effort — used to locate the right event)" },
              "new_slot_datetime": { "type": "string" },
              "reason": { "type": "string" }
            },
            "required": ["patient_name", "current_slot_datetime", "new_slot_datetime"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "find_appointment",
          "description": "Look up a patient's existing appointment by name and approximate date/time — read-only, no changes made. Use this when a patient is asking about an existing appointment (confirming details, checking the time) rather than booking, rescheduling, or cancelling.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "approximate_datetime": { "type": "string", "description": "The date/time the patient believes their appointment is at, ISO 8601 (best effort — used to locate the right event)" }
            },
            "required": ["patient_name"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "check_waitlist",
          "description": "Check whether any waitlisted patients match a newly freed slot's visit type and date window.",
          "parameters": {
            "type": "object",
            "properties": {
              "visit_type": { "type": "string" },
              "date_range_start": { "type": "string" },
              "date_range_end": { "type": "string" }
            },
            "required": ["visit_type", "date_range_start", "date_range_end"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "add_to_waitlist",
          "description": "Add a patient to the waitlist for a visit type within a preferred date window.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "phone": { "type": "string" },
              "visit_type": { "type": "string" },
              "preferred_window_start": { "type": "string" },
              "preferred_window_end": { "type": "string" }
            },
            "required": ["patient_name", "phone", "visit_type", "preferred_window_start", "preferred_window_end"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "create_calendar_event",
          "description": "Create a Google Calendar event for a confirmed appointment.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "visit_type": { "type": "string" },
              "provider": { "type": "string" },
              "slot_datetime": { "type": "string" },
              "duration_minutes": { "type": "number" }
            },
            "required": ["patient_name", "visit_type", "provider", "slot_datetime"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "log_call_summary",
          "description": "Log the outcome of the call to the practice's patient/appointment sheet. Call this at the end of every call.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": { "type": "string" },
              "outcome": {
                "type": "string",
                "enum": ["booked", "rescheduled", "waitlisted", "cancelled", "info_only", "escalated_urgent"]
              },
              "notes": { "type": "string" }
            },
            "required": ["patient_name", "outcome"]
          }
        }
      }
    ]
  },
  "voice": {
    "provider": "11labs",
    "voiceId": "REPLACE_WITH_CHOSEN_VOICE_ID"
  },
  "transcriber": {
    "provider": "deepgram",
    "model": "nova-2",
    "language": "en-US"
  },
  "serverUrl": "REPLACE_WITH_YOUR_WEBHOOK_URL",
  "endCallFunctionEnabled": true,
  "startSpeakingPlan": {
    "smartEndpointingEnabled": true
  },
  "stopSpeakingPlan": {
    "numWords": 3,
    "voiceSeconds": 0.3,
    "backoffSeconds": 1
  }
}

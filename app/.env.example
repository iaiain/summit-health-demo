# Client-side (Vite exposes anything prefixed VITE_ to the browser — public key only, never secrets)
VITE_VAPI_PUBLIC_KEY=
VITE_VAPI_ASSISTANT_ID=

# Server-side only (Vercel serverless functions in /api — never prefix these with VITE_)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_CALENDAR_ID=
PUBLIC_BASE_URL=
